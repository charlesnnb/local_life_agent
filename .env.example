# Local Life Planning Agent — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For local development with fallback (real APIs optional):
#   APP_MODE=development
#
# For competition/demo (all real APIs required):
#   APP_MODE=demo
#
# For automated testing (all mock, no API keys needed):
#   APP_MODE=test

# Application mode: development | demo | test
APP_MODE=development

# DeepSeek API key (required in demo mode)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Amap (高德地图) API key (required in demo mode)
# Get from: https://console.amap.com/dev/key/app
AMAP_API_KEY=

# Server configuration
HOST=0.0.0.0
PORT=8000
