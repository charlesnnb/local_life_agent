# Local Life Agent — Environment Configuration
#
# Copy to .env and fill in values as needed:
#   cp .env.example .env

# Runtime mode: demo | hybrid | live
# Overridden by ./run.sh <mode> at startup.
RUN_MODE=demo

# Optional demo exception scenario: normal | restaurant_full | activity_unavailable | traffic_delay
DEMO_SCENARIO=normal

# DeepSeek API (required for hybrid / live)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=6

# AMap Web Service API (required for hybrid / live)
# Use AMAP_WEB_SERVICE_KEY; AMAP_API_KEY is a legacy alias.
AMAP_WEB_SERVICE_KEY=
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_TIMEOUT_SECONDS=5

# Compatibility flags — ./run.sh sets these automatically per mode.
USE_MOCK_LLM=
USE_MOCK_AMAP=
USE_MOCK_ACTIONS=
ENABLE_LLM=
ENABLE_AMAP=
DEMO_MODE=

# Server
HOST=0.0.0.0
PORT=8000
